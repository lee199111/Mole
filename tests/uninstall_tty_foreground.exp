#!/usr/bin/expect -f

set timeout 4
set project_root [lindex $argv 0]

spawn env "PS1=PROMPT> " /bin/zsh -df
expect {
    -re {PROMPT> } {}
    timeout { exit 124 }
    eof { exit 1 }
}

send -- "/bin/bash '$project_root/tests/uninstall_tty_foreground_fixture.sh' '$project_root'\r"
expect {
    -re {TTY-STATE:foreground\r?\n} {}
    timeout { exit 124 }
    eof { exit 1 }
}
expect {
    -re {PROMPT> } {}
    timeout { exit 124 }
    eof { exit 1 }
}

send -- "/bin/bash '$project_root/tests/uninstall_tty_foreground_fixture.sh' '$project_root' &\r"

expect {
    -re {TTY-STATE:background\r?\n} {}
    timeout { exit 124 }
    eof { exit 1 }
}

expect {
    -re {PROMPT> } {}
    timeout { exit 124 }
    eof { exit 1 }
}

send -- "exit\r"
expect eof
